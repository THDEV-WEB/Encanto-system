# Copie para .env.e2e (raiz do projeto, gitignored) e preencha quando o projeto Supabase
# DEDICADO a E2E existir (REF-E2E-01 — nunca aponte isto para o Supabase de produção).
# Carregado automaticamente pelo Vite quando os testes sobem o app via `vite --mode e2e`
# (ver e2e/playwright.config.js). Enquanto estas 2 variáveis abaixo estiverem vazias, o app
# roda em modo degradado com o catálogo MOCK (src/data/mockCatalog.js) — é assim que a Onda 1
# (infra + specs read-only/locais) já funciona hoje, sem precisar do projeto de E2E pronto.

# -- Usadas pelo APP (Vite injeta no browser — só variáveis VITE_* chegam ao bundle) --
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
VITE_WHATSAPP=5500000000000
VITE_RPC_TIMEOUT=12000

# -- Usada só pelos scripts Node de setup/teardown (e2e/support/*.js) --
# NUNCA prefixar com VITE_: o Vite só expõe ao browser variáveis VITE_*, então mesmo estando
# neste arquivo, esta chave não entra no bundle. Mesmo assim, NUNCA comitar o valor real —
# service_role ignora RLS por completo (é a chave de administração total do projeto).
E2E_SUPABASE_SERVICE_ROLE_KEY=
