# Copie para .env e preencha com seus valores reais.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_KEY=sua_chave_publishable_ou_anon
VITE_WHATSAPP=55DDDNUMERO
# Timeout da RPC (ms). Fallback seguro = 12000. Ex.: produção 8000, desenvolvimento 30000.
VITE_RPC_TIMEOUT=12000

# REF-OBS-01 (opcional): sem isto, o app funciona 100% igual, só sem reportar erros ao Sentry.
# DSN do projeto Sentry (Settings > Client Keys). Fica exposto no bundle (é assim que o SDK do
# navegador funciona) — não é segredo, só um endereço de ingestão.
VITE_SENTRY_DSN=

# REF-OBS-01 (opcional, só em BUILD — nunca prefixo VITE_, nunca vai pro bundle do navegador):
# credenciais para subir source maps ao Sentry (stack traces legíveis em produção). Sem elas, o
# build gera o app normalmente, só sem sourcemap nenhum (nada fica público por engano).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
